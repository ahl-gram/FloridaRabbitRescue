---
layout: base.njk
title: Directory
description: All verified Florida rabbit rescue organizations — mission statements, 501(c)(3) status, founding dates, and board transparency.
---

<section class="directory-hero">
  <h1>Florida Rabbit Rescue Directory</h1>
  <p>{{ directory.organizations | length }} rabbit rescue organizations in Florida.</p>
</section>

<div class="directory-intro">
  <p>Listings include mission statements (verbatim where possible), founding dates, tax-exempt status, and board transparency details where available — all sourced from publicly available records. Not every organization listed has confirmed 501(c)(3) status; each listing indicates what has been verified.</p>
  <p>This directory was last verified in <strong>{{ directory.meta.last_verified }}</strong>. If you represent an organization listed here and need to update your information, please <a href="/contact/">contact us</a>.</p>
</div>

<div class="disclaimer">
  <strong>Note:</strong> This directory does not rank or score rescue organizations. Information is presented as objective, publicly verifiable facts. Organizations are listed alphabetically.
</div>

<div class="directory-list">
  {%- for org in directory.organizations | sortByName %}
  <article class="directory-card" id="{{ org.id }}">
    <div class="card-header">
      <div class="card-header-info">
        <div class="org-name"><a href="#{{ org.id }}" class="org-name-link">{{ org.name }}</a></div>
        <div class="org-location">{{ org.location.city }}, {{ org.location.state }} · {{ org.location.region }}</div>
        <div class="org-area">{{ org.service_area }}</div>
      </div>
      <div class="card-badge-col">
        {%- if org.nonprofit.status == "confirmed" or org.nonprofit.status == "confirmed_via_guidestar" %}
        <span class="badge badge-green">✓ 501(c)(3)</span>
        {%- elif org.nonprofit.status == "inactive" %}
        <span class="badge badge-muted">Sunbiz Inactive</span>
        {%- else %}
        <span class="badge badge-muted">501(c)(3) Not Confirmed</span>
        {%- endif %}
        {%- if org.founded %}
        <span class="badge badge-earth">Est. {{ org.founded }}</span>
        {%- endif %}
      </div>
    </div>

    {%- if org.mission_statement %}
    <div class="card-mission">
      <div class="card-field-label">Mission statement</div>
      <div class="card-mission-text">"{{ org.mission_statement }}"</div>
    </div>
    {%- endif %}

    <div class="card-facts">
      <div class="fact-cell">
        <div class="card-field-label">501(c)(3) status</div>
        <div class="fact-value">
          {%- if org.nonprofit.status == "confirmed" or org.nonprofit.status == "confirmed_via_guidestar" %}Confirmed{% else %}{{ org.nonprofit.status_label }}{% endif -%}
        </div>
        {%- if org.nonprofit.ein %}
        <div class="fact-sub">EIN: {% if org.nonprofit.candid_url %}<a href="{{ org.nonprofit.candid_url }}" target="_blank" rel="noopener">{{ org.nonprofit.ein }}</a>{% else %}{{ org.nonprofit.ein }}{% endif %}</div>
        {%- endif %}
        {%- if org.nonprofit.sunbiz_document_number %}
        <div class="fact-sub">Sunbiz: {% if org.nonprofit.sunbiz_url %}<a href="{{ org.nonprofit.sunbiz_url }}" target="_blank" rel="noopener">{{ org.nonprofit.sunbiz_document_number }}</a>{% else %}{{ org.nonprofit.sunbiz_document_number }}{% endif %}</div>
        {%- endif %}
        {%- if org.nonprofit.sunbiz_note %}
        <div class="fact-sub">{{ org.nonprofit.sunbiz_note }}</div>
        {%- endif %}
      </div>
      <div class="fact-cell">
        <div class="card-field-label">In operation</div>
        {%- if org.founded %}
        <div class="fact-value">Since {{ org.founded }}</div>
        <div class="fact-sub">{{ org.years_active }} year{{ "s" if org.years_active != 1 }} active</div>
        {%- else %}
        <div class="fact-value">Unknown</div>
        {%- endif %}
      </div>
      <div class="fact-cell">
        <div class="card-field-label">Model</div>
        <div class="fact-value">{{ org.model | modelLabel }}</div>
        <div class="fact-sub">{{ org.species_focus | speciesLabel }}</div>
      </div>
    </div>

    <div class="card-facts">
      <div class="fact-cell">
        <div class="card-field-label">Board of Directors</div>
        <div class="board-status">
          <span class="status-dot dot-muted"></span>
          {%- if org.board.status == "publicly_listed" %} Listed on website
          {%- elif org.board.sunbiz_principals_count %} {{ org.board.sunbiz_principals_count }} principal{{ "s" if org.board.sunbiz_principals_count != 1 }} on Sunbiz
          {%- else %} {{ org.board.status_label }}
          {%- endif %}
        </div>
      </div>
      <div class="fact-cell"></div>
      <div class="fact-cell">
        {%- if org.social %}
        <div class="card-field-label">Social</div>
        <div class="social-icons">
          {%- if org.social.facebook %}
          <a href="{{ org.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          {%- endif %}
          {%- if org.social.instagram %}
          <a href="{{ org.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403a4.088 4.088 0 011.523.99 4.088 4.088 0 01.99 1.524c.163.46.349 1.26.403 2.43.058 1.265.07 1.645.07 4.849s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43a4.088 4.088 0 01-.99 1.523 4.088 4.088 0 01-1.524.99c-.46.163-1.26.349-2.43.403-1.265.058-1.645.07-4.849.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403a4.088 4.088 0 01-1.523-.99 4.088 4.088 0 01-.99-1.524c-.163-.46-.349-1.26-.403-2.43C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43a4.088 4.088 0 01.99-1.523A4.088 4.088 0 015.15 2.636c.46-.163 1.26-.349 2.43-.403C8.845 2.175 9.225 2.163 12 2.163zm0-2.163C8.741 0 8.333.014 7.053.072 5.775.13 4.902.333 4.14.63a6.21 6.21 0 00-2.245 1.462A6.21 6.21 0 00.433 4.337C.136 5.1-.067 5.973-.009 7.25.005 8.53 0 8.939 0 12.198c0 3.259.014 3.668.072 4.948.058 1.277.261 2.15.558 2.913a6.21 6.21 0 001.462 2.245 6.21 6.21 0 002.245 1.462c.763.297 1.636.5 2.913.558C8.53 24.382 8.939 24.396 12 24.396s3.47-.014 4.75-.072c1.277-.058 2.15-.261 2.913-.558a6.21 6.21 0 002.245-1.462 6.21 6.21 0 001.462-2.245c.297-.763.5-1.636.558-2.913.058-1.28.072-1.689.072-4.948s-.014-3.668-.072-4.948c-.058-1.277-.261-2.15-.558-2.913a6.21 6.21 0 00-1.462-2.245A6.21 6.21 0 0019.663.63C18.9.333 18.027.13 16.75.072 15.47.014 15.061 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a3.999 3.999 0 110-7.998 3.999 3.999 0 010 7.998zm6.406-10.845a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg>
          </a>
          {%- endif %}
          {%- if org.social.tiktok %}
          <a href="{{ org.social.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="social-icon">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.18 8.18 0 004.76 1.52V6.84a4.84 4.84 0 01-1-.15z"/></svg>
          </a>
          {%- endif %}
        </div>
        {%- endif %}
      </div>
    </div>

    {%- if org.caveats %}
    <div class="card-caveats">
      <div class="card-field-label">Important notes</div>
      <ul class="caveats-list">
        {%- for caveat in org.caveats %}
        <li>{{ caveat }}</li>
        {%- endfor %}
      </ul>
    </div>
    {%- endif %}

    <div class="card-footer-row">
      <span class="verified-tag">Last verified: {{ org.last_verified }}</span>
      {%- if org.website %}
      <a class="card-cta" href="{{ org.website }}" target="_blank" rel="noopener">↗ {{ org.website | replace("https://www.", "") | replace("https://", "") }}</a>
      {%- elif org.linktree_url %}
      <a class="card-cta" href="{{ org.linktree_url }}" target="_blank" rel="noopener">↗ Linktree</a>
      {%- elif org.social and org.social.facebook %}
      <a class="card-cta" href="{{ org.social.facebook }}" target="_blank" rel="noopener">↗ Facebook</a>
      {%- endif %}
    </div>
  </article>
  {%- endfor %}
</div>

<div class="directory-notes">
  <h2>Closed Organizations</h2>
  <ul>
    {%- for org in directory.closed_organizations %}
    <li>
      <strong>{{ org.name }}</strong> — {{ org.reason }}
      {%- if org.url %} · <a href="{{ org.url }}" target="_blank" rel="noopener">{{ org.url | replace("https://", "") }}</a>{% endif %}
    </li>
    {%- endfor %}
  </ul>

  <h2>Other Rabbit-Friendly Organizations</h2>
  <p class="excluded-intro">The following organizations were reviewed but not included in the main directory, typically because their primary focus extends beyond rabbits. They may still have rabbits available for adoption — we encourage you to reach out to them directly.</p>
  <ul>
    {%- for org in directory.excluded_organizations | sortByName %}
    <li>
      <strong>{{ org.name }}</strong>
      {%- if org.url %} · <a href="{{ org.url }}" target="_blank" rel="noopener">{{ org.url | replace("https://", "") }}</a>{% endif %}
    </li>
    {%- endfor %}
  </ul>

  <h2>Shelters, Humane Societies, SPCAs, and County Services</h2>
  <p class="excluded-intro">The following shelters and government animal services may have rabbits available for adoption. Contact them directly to ask about rabbit availability.</p>
  <ul>
    {%- for org in directory.shelters_and_services | sortByName %}
    <li>
      <strong>{{ org.name }}</strong>
      {%- if org.url %} · <a href="{{ org.url }}" target="_blank" rel="noopener">{{ org.url | replace("https://www.", "") | replace("https://", "") }}</a>{% endif %}
    </li>
    {%- endfor %}
  </ul>

  <div class="correction-cta">
    <p>Is your organization missing or incorrect?</p>
    <a class="btn-primary" href="/contact/">Submit a Correction →</a>
  </div>
</div>
